# Database (remote — e.g. Neon, RDS, Supabase)
# Copy this file to .env.local and paste the connection string from your provider.
# Neon: Dashboard → your project → Connect → use the pooled connection string for apps/serverless; keep ?sslmode=require
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"

# NextAuth
NEXTAUTH_SECRET="your-secret-key-here"
NEXTAUTH_URL="http://localhost:3000"

# Field-level encryption for sensitive medical data (generate with: openssl rand -base64 32)
ENCRYPTION_SECRET="your-encryption-secret-here"

# Redis (Upstash) - for rate limiting at scale
# Get these from https://console.upstash.com
UPSTASH_REDIS_REST_URL="https://your-endpoint.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-token-here"
